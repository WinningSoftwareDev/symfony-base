{
  "name": "winningsoftware/symfony-base",
  "description": "A base Symfony 7.3 project template with Latte + Vue",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.4",
    "cloudbase/asset-node": "^1.0",
    "cloudbase/latte-helper": "^1.2.1",
    "doctrine/dbal": "^4.3",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/orm": "^3.5",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/form": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/mailer": "^8.0",
    "symfony/mime": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/validator": "^8.0",
    "symfony/var-exporter": "<8.0",
    "symfony/yaml": "^8.0"
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "stan": "php -d memory_limit=2G ./vendor/bin/phpstan analyse -c phpstan.neon",
    "cs": "./vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes",
    "cache:clean": "./bin/console cache:clear --env=prod --no-debug && ./bin/console cache:warmup --env=prod",
    "post-create-project-cmd": [
      "@php -r \"copy('.env.template', '.env');\"",
      "@php bin/console app:install",
      "mkdir -p var/cache var/log && chmod -R 777 var/",
      "rm -rf src/Application/Classes/ src/Application/Command/SetupCommand.php screenshots/"
    ]
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.89",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-doctrine": "^2.0"
  }
}
