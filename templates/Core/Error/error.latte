{varType string $heading}
{varType string $text}

<div class="h-screen w-screen flex items-center justify-center flex-col gap-8 px-6">
    <img src="/images/bee.png" class="w-80 h-auto" alt="Sad Bee" />
    <h1 class="font-bold text-2xl text-center">{$heading}</h1>
    <p>{$text}</p>
    <a href="/" class="hover:text-primary transition duration-150">Go back to the homepage</a>
</div>