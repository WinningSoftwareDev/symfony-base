{
  "compilerOptions": {
    "outDir": "./public/assets/",
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ESNext"]
  },
  "include": [
    "assets/scripts/**",
    "vite.config.ts"
  ]
}